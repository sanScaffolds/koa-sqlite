{
  "name": "backend",
  "version": "1.0.0",
  "description": "Koa + SQLite 后端项目骨架",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & nodemon dist/index.js",
     "migrate": "node --require ts-node/register ./node_modules/.bin/knex migrate:latest",
     "migrate:rollback": "node --require ts-node/register ./node_modules/.bin/knex migrate:rollback",
     "seed": "node --require ts-node/register ./node_modules/.bin/knex seed:run"
  },
  "keywords": [
    "koa",
    "sqlite",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "joi": "^17.13.0",
    "knex": "^3.1.0",
    "koa": "^3.2.0",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^14.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/koa": "^3.0.2",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-router": "^7.4.9",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
